<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .card { background: white; padding: 2.5rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); width: 100%; max-width: 350px; text-align: center; }
        h1 { color: #333; margin-top: 0; }
        .info-box { background-color: #f8fafc; border: 1px solid #e2e8f0; padding: 15px; border-radius: 8px; text-align: left; margin-bottom: 20px; }
        .info-box p { margin: 8px 0; color: #475569; font-size: 14px; }
        .info-box span { font-weight: bold; color: #1e293b; }
        button { width: 100%; padding: 12px; border: none; border-radius: 6px; font-size: 16px; font-weight: bold; cursor: pointer; transition: background 0.3s; background-color: #ef4444; color: white; }
        button:hover { background-color: #dc2626; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Your Profile</h1>
        <div class="info-box">
            <p>User ID: <span><%= user.userId %></span></p>
            <p>Email: <span><%= user.email %></span></p>
        </div>
        <form method="POST" action="/logout">
            <button type="submit">Logout</button>
        </form>
    </div>
</body>
</html>